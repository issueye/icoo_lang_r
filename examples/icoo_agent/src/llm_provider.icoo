import "std.env" as env
import "std.json" as json
import "std.net.http.client" as http

export fn real_next_assistant_message(turn: Int, messages: Array<Map<String, Any>>) {
    let api_key = env.get("ICOO_AGENT_API_KEY")
    let base_url = env.get("ICOO_AGENT_BASE_URL")
    let model = env.get("ICOO_AGENT_MODEL")

    if base_url == nil {
        base_url = "https://api.openai.com"
    }
    if model == nil {
        model = "gpt-5.5"
    }
    let api_key_text = api_key.to_string()
    let base_url_text = base_url.to_string()
    let model_text = model.to_string()

    let prompt = build_turn_prompt(turn, messages.len())
    let body = {
        "model": model_text,
        "instructions": "You are the provider inside a Pi-style coding agent harness. Return only valid JSON.",
        "input": prompt,
        "temperature": 0,
        "max_output_tokens": 500
    }
    let response = send_chat_request(responses_url(base_url_text), json.stringify(body), {
        "Authorization": "Bearer " + api_key_text,
        "Content-Type": "application/json"
    })

    if response.get("status") != 200 {
        if turn >= 3 {
            return {
                "role": "assistant",
                "content": "The real provider tool loop completed, but the final summary call returned HTTP " + response.get("status").to_string() + ".",
                "tool_calls": []
            }
        }
        return {
            "role": "assistant",
            "content": "LLM provider returned HTTP " + response.get("status").to_string(),
            "tool_calls": []
        }
    }

    let data = json.parse(response.get("body"))
    let content = data.get("output").at(0).get("content").at(0).get("text")
    return normalize_assistant_message(json.parse(content))
}

fn responses_url(base_url: String) -> String {
    if base_url.contains("/v1") {
        return base_url + "/responses"
    }
    return base_url + "/v1/responses"
}

fn send_chat_request(url: String, body: String, headers: Map<String, String>) -> Map<String, Any> {
    let attempt = 0
    let last_error = ""
    while attempt < 3 {
        try {
            return http.post(url, body, headers)
        } catch err {
            last_error = err
        }
        attempt = attempt + 1
    }
    return {
        "status": 599,
        "body": last_error
    }
}

fn build_turn_prompt(turn: Int, message_count: Int) -> String {
    let instruction = "Return exactly one JSON object with keys role, content, tool_calls. Do not use markdown fences. Current message count is " + message_count.to_string() + ". "
    
    return match turn {
        0 => instruction + "For turn 0, return tool_calls exactly as [{\"name\":\"bash\",\"args\":{\"command\":\"echo icoo-agent real provider\"}}].",
        1 => instruction + "For turn 1, return tool_calls exactly as [{\"name\":\"write_file\",\"args\":{\"path\":\"target/icoo_agent_note.txt\",\"content\":\"icoo_agent completed a real-provider tool loop.\"}}].",
        2 => instruction + "For turn 2, return tool_calls exactly as [{\"name\":\"read_file\",\"args\":{\"path\":\"target/icoo_agent_note.txt\"}}].",
        _ => instruction + "For this final turn, return no tool calls and summarize that the real provider planned, used tools, verified the file, and saved the session.",
    }
}

fn normalize_assistant_message(message: Any) -> Map<String, Any> {
    let calls = []
    let raw_calls = message.get("tool_calls")

    if raw_calls != nil {
        let index = 0
        while index < raw_calls.len() {
            let normalized = normalize_tool_call(raw_calls.at(index))
            if normalized != nil {
                calls.push(normalized)
            }
            index = index + 1
        }
    }

    let content = message.get("content")
    if content == nil {
        content = ""
    }

    return {
        "role": "assistant",
        "content": content,
        "tool_calls": calls
    }
}

fn normalize_tool_call(call: Any) {
    if call.has("name") {
        return {
            "name": call.get("name"),
            "args": call.get("args")
        }
    }

    let function_call = call.get("function")
    if function_call == nil {
        return nil
    }

    let args = function_call.get("arguments")
    if args == nil {
        args = {}
    } else {
        if args.type_name() == "String" {
            args = json.parse(args)
        }
    }

    return {
        "name": function_call.get("name"),
        "args": args
    }
}
