import "std.io.fs" as fs
import "std.path" as path
import "std.process" as process

export fn tool_specs() -> Array<Map<String, Any>> {
    return [
        {
            "name": "bash",
            "description": "Run a local shell command and return stdout, stderr, and exit status.",
            "args": {
                "command": "String"
            },
            "enabled": true,
            "dangerous": true,
            "timeout_ms": 3000,
            "retry_safe": false
        },
        {
            "name": "write_file",
            "description": "Write UTF-8 text to a local file.",
            "args": {
                "path": "String",
                "content": "String"
            },
            "enabled": true,
            "dangerous": true,
            "timeout_ms": 3000,
            "retry_safe": false
        },
        {
            "name": "read_file",
            "description": "Read UTF-8 text from a local file.",
            "args": {
                "path": "String"
            },
            "enabled": true,
            "dangerous": false,
            "timeout_ms": 3000,
            "retry_safe": true
        }
    ]
}

export fn tool_spec_summary(specs: Array<Map<String, Any>>) -> String {
    let lines = []
    let index = 0
    while index < specs.len() {
        let spec = specs.at(index)
        lines.push("- " + spec.get("name") + ": " + spec.get("description") + " args=" + spec.get("args").to_string())
        index = index + 1
    }
    return lines.join("\n")
}

export fn execute_tool(config: Map<String, Any>, call: Map<String, Any>) -> Map<String, Any> {
    let name = call.get("name")
    let args = call.get("args")

    if name == nil {
        return {
            "ok": false,
            "content": "tool call missing name"
        }
    }
    if args == nil {
        args = {}
    }

    let preflight = preflight_tool(config, name.to_string(), args)
    if preflight.get("ok") == false {
        return preflight
    }

    if name == "bash" {
        return run_bash(args)
    }
    if name == "write_file" {
        return write_file(args)
    }
    if name == "read_file" {
        return read_file(args)
    }

    return {
        "ok": false,
        "content": "unknown tool: " + name.to_string()
    }
}

fn preflight_tool(config: Map<String, Any>, name: String, args: Map<String, Any>) -> Map<String, Any> {
    if name == "bash" and config.get("tools").get("allow_bash") == false {
        return blocked("bash tool is disabled by config")
    }
    if name == "write_file" or name == "read_file" {
        let requested = args.get("path")
        if requested == nil {
            requested = args.get("file_path")
        }
        if requested == nil {
            requested = args.get("filename")
        }
        if requested != nil and not path_allowed(config, requested.to_string()) {
            return blocked("path is outside workspace_root: " + requested.to_string())
        }
    }
    return {
        "ok": true,
        "content": "allowed"
    }
}

fn blocked(reason: String) -> Map<String, Any> {
    return {
        "ok": false,
        "blocked": true,
        "content": reason
    }
}

fn path_allowed(config: Map<String, Any>, requested: String) -> Bool {
    let root = config.get("tools").get("workspace_root")
    if root == nil {
        root = "."
    }
    let normalized_root = path.normalize(root.to_string())
    let normalized_path = path.normalize(requested)
    if normalized_root == "." {
        return not path.is_absolute(normalized_path) and normalized_path != ".." and normalized_path != "../" and normalized_path != "..\\"
    }
    return normalized_path == normalized_root or not path.is_absolute(normalized_path)
}

fn run_bash(args: Map<String, Any>) -> Map<String, Any> {
    let command = args.get("command")
    if command == nil {
        command = args.get("cmd")
    }
    if command == nil {
        return {
            "ok": false,
            "content": "bash tool missing command"
        }
    }

    let result = process.exec(command, {
        "timeout_ms": 3000,
        "max_output_bytes": 8192
    })
    return {
        "ok": result.get("success"),
        "content": result.get("stdout"),
        "stderr": result.get("stderr"),
        "exit_code": result.get("exit_code")
    }
}

fn write_file(args: Map<String, Any>) -> Map<String, Any> {
    let path = args.get("path")
    if path == nil {
        path = args.get("file_path")
    }
    if path == nil {
        path = args.get("filename")
    }

    let content = args.get("content")
    if content == nil {
        content = args.get("text")
    }
    if content == nil {
        content = args.get("body")
    }

    if path == nil {
        return {
            "ok": false,
            "content": "write_file tool missing path"
        }
    }
    if content == nil {
        return {
            "ok": false,
            "content": "write_file tool missing content"
        }
    }

    fs.write_text(path, content)
    return {
        "ok": true,
        "content": "wrote " + path
    }
}

fn read_file(args: Map<String, Any>) -> Map<String, Any> {
    let path = args.get("path")
    if path == nil {
        path = args.get("file_path")
    }
    if path == nil {
        path = args.get("filename")
    }
    if path == nil {
        return {
            "ok": false,
            "content": "read_file tool missing path"
        }
    }
    return {
        "ok": true,
        "content": fs.read_text(path)
    }
}
